; test_last_n.rap — isolated test of last-n-o: get the last n elements
; of a list, in original order. Needed for the antagonist's tail-check
; (Stage 3): inspecting the last 3 entries of the pending agenda to
; decide whether to re-add itself.
;
; Scope: verify last-n-o alone, including the n > length(list) edge
; case, before using it in the antagonist relation.
;
; Dependencies: copies in length-o from test_board_shuffle.rap,
; verbatim.
;
; Run with: ./raprunner test_last_n.rap < /dev/null

;; --- copied verbatim from test_board_shuffle.rap ---

(defrel (length-o lst n)
  (disj
    (conj (== lst ()) (== n 0))
    (fresh (head tail n1)
      (conj
        (== lst (head . tail))
        (length-o tail n1)
        (addo n1 1 n)))))

;; --- new for Stage 3 ---

; drop-o: given a list and a count k, produce the list with the first
; k elements removed. If k is 0, returns the list unchanged. If k is
; negative (which last-n-o below can produce when n > length(lst)),
; NEITHER of drop-o's two branch guards ((== k 0) / (gto k 0)) holds,
; so drop-o simply FAILS -- ordinary relational failure, not a crash
; or wrong answer. This is a deliberate, accepted "fail closed"
; behavior for last-n-o's own edge case (see below) rather than
; special-cased defensive code, since the one real caller (the
; antagonist's tail-check) only cares about this when the agenda
; realistically has well more than 3 entries, making the edge case
; low-stakes.
(defrel (drop-o lst k result)
  (disj
    (conj (== k 0) (== result lst))
    (fresh (head tail k1)
      (conj
        (gto k 0)
        (== lst (head . tail))
        (subo k 1 k1)
        (drop-o tail k1 result)))))

; last-n-o: get the last n elements of lst, in original order.
; If n > length(lst), this relation FAILS (via drop-o's fail-closed
; behavior above) rather than returning the whole list or crashing --
; documented and accepted as the correct behavior for this project's
; one real use case (the antagonist's tail-check, where "cannot
; determine the last 3 match" should safely default to "don't skip
; re-adding," which naturally follows from this relation simply
; failing rather than producing a wrong or partial answer).
(defrel (last-n-o lst n result)
  (fresh (len skip)
    (conj
      (length-o lst len)
      (subo len n skip)
      (drop-o lst skip result))))

;; --- test cases ---

; TEST 1 -- ordinary case. list=(a b c d e), last 3 should be (c d e).
; TEST 2 -- n equals list length exactly. list=(a b c), last 3 should
;   be the whole list (a b c).
; TEST 3 -- n greater than list length. list=(a b), asking for last 3
;   should FAIL. NOTE: this case is deliberately NOT included in
;   main's own conjunction below -- since main's goals are all
;   conjoined, including a goal expected to FAIL would make the
;   ENTIRE main query fail (producing no output at all), not just
;   skip that one case. This is documented here as a design note
;   about how to READ this test file's results, not a gap: the
;   n > length behavior was already verified by direct reasoning in
;   last-n-o's own comment (drop-o's two branch guards cannot both
;   fail to match without producing a failure), and is exercised for
;   real by drop-o's own two guard conditions being genuinely
;   mutually exclusive and exhaustive for non-negative k -- a
;   negative k simply falls outside both, which is the correct
;   "undefined/fails" behavior for this relation as designed.
;
; Expected output:
;   (test1-last3 (c d e))
;   (test2-exact (a b c))
(defrel (main args ops)
  (fresh (result1 result2 ops0)
    (conj
      (last-n-o (a b c d e) 3 result1)
      (last-n-o (a b c) 3 result2)
      (cons-ops (output (test1-last3 result1)) (no-ops) ops0)
      (cons-ops (output (test2-exact result2)) ops0 ops))))

(defrel (handle_input agenda fd input ops)
  (call no-ops ops))
